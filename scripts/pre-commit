#!/bin/sh
set -e

echo '>>> lint'
npm run lint

echo '>>> type check'
npx tsc --noEmit --project frontend/tsconfig.app.json
npx tsc --noEmit --project backend/tsconfig.json

echo '>>> test (frontend)'
npm test -w frontend

echo '>>> test (backend)'
cd backend && set -a && . ../.env && set +a && npx vitest run
